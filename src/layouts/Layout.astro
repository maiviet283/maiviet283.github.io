---
import type { Locale } from '../types'
import '../theme.css'
import '../App.css'

interface Props {
  lang: 'vi' | 'en'
  text: Locale
}

const { lang, text } = Astro.props

const siteUrl = 'https://maiviet.vietdon.vn'
const path = lang === 'en' ? '/en/' : '/'
const canonical = `${siteUrl}${path}`
const ogLocale = lang === 'en' ? 'en_US' : 'vi_VN'
const ogLocaleAlternate = lang === 'en' ? 'vi_VN' : 'en_US'

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Mai Quốc Việt',
  alternateName: ['Mai Quoc Viet', 'maiviet283'],
  url: siteUrl,
  image: `${siteUrl}/avatar.jpg`,
  jobTitle: 'Backend Developer',
  description:
    'Backend developer trẻ từ Đà Nẵng, đang xây dựng VietDon – nền tảng donate online cho creator Việt Nam.',
  worksFor: {
    '@type': 'Organization',
    name: 'SapotarCorp',
    url: 'https://www.sapotacorp.vn/',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'VKU – Trường Đại học Công nghệ Thông tin và Truyền thông Việt – Hàn',
    alternateName: ['VKU', 'Trường Việt Hàn', 'Vietnam-Korea University of Information and Communication Technology'],
    sameAs: 'https://vku.udn.vn/',
  },
  identifier: [
    {
      '@type': 'PropertyValue',
      name: 'Mã sinh viên VKU',
      value: '21IT595',
    },
    {
      '@type': 'PropertyValue',
      name: 'Lớp',
      value: '21NS',
    },
  ],
  nationality: {
    '@type': 'Country',
    name: 'Việt Nam',
  },
  knowsLanguage: ['vi', 'en'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Đà Nẵng',
    addressCountry: 'VN',
  },
  birthPlace: {
    '@type': 'Place',
    name: 'Kỳ Khang, Kỳ Anh, Hà Tĩnh, Việt Nam',
  },
  homeLocation: {
    '@type': 'Place',
    name: 'Đà Nẵng, Việt Nam',
  },
  email: 'maiviet283@gmail.com',
  sameAs: [
    'https://github.com/maiviet283',
    'https://www.facebook.com/maiviet283',
    'https://www.linkedin.com/in/maiviet283/',
    'https://www.tiktok.com/@maiviet283',
    'https://www.instagram.com/maiviet283',
  ],
  knowsAbout: [
    'Python', 'Django', 'FastAPI', 'Node.js', 'C#', '.NET',
    'PostgreSQL', 'MySQL', 'Redis', 'Docker', 'Nginx',
    'React', 'TypeScript', 'Backend Development', 'Creator Economy', 'VietQR',
  ],
}

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Mai Quốc Việt – Profile',
  url: siteUrl,
  description:
    'Trang cá nhân của Mai Quốc Việt (maiviet283) – Backend developer từ Đà Nẵng, founder VietDon.',
  author: {
    '@type': 'Person',
    name: 'Mai Quốc Việt',
  },
  hasPart: [
    { '@type': 'WebPage', name: 'VietDon', url: `${siteUrl}/vietdon/` },
    { '@type': 'WebPage', name: 'Dự án', url: `${siteUrl}/projects/` },
    { '@type': 'WebPage', name: 'Giới thiệu', url: `${siteUrl}/about/` },
  ],
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />

    <!-- Favicons / App icons (192px = multiple of 48px, required for Google Search) -->
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f5402c" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{text.meta.pageTitle}</title>
    <meta name="title" content={text.meta.pageTitle} />
    <meta name="description" content={text.meta.description} />
    <meta name="keywords" content="Mai Quốc Việt, Mai Quoc Viet, maiviet283, VietDon, Mai Quốc Việt Hà Tĩnh, Mai Quốc Việt Kỳ Anh, Mai Quốc Việt Kỳ Khang, Mai Quốc Việt VietDon, Mai Quốc Việt Đà Nẵng, backend developer Đà Nẵng, lập trình viên Đà Nẵng, lập trình Đà Nẵng, Python developer Vietnam, Django developer, FastAPI, creator economy Vietnam, donate online Việt Nam, profile Mai Quốc Việt" />
    <meta name="author" content="Mai Quốc Việt" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Language alternates -->
    <link rel="alternate" hreflang="vi" href={`${siteUrl}/`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <!-- Open Graph / Facebook / Zalo -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={text.meta.pageTitle} />
    <meta property="og:description" content={text.meta.description} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={text.meta.pageTitle} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:site_name" content="Mai Quốc Việt – maiviet.vietdon.vn" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={text.meta.pageTitle} />
    <meta name="twitter:description" content={text.meta.description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />
    <meta name="twitter:creator" content="@maiviet283" />

    <!-- Geo -->
    <meta name="geo.region" content="VN-DN" />
    <meta name="geo.placename" content="Đà Nẵng, Việt Nam" />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />

    <!-- Apply saved theme before first paint to avoid flashing.
         The "js" class enables the reveal-on-scroll hidden state. -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js')
        var theme = 'dark'
        try {
          theme = localStorage.getItem('theme') || 'dark'
        } catch (error) {}
        document.documentElement.dataset.theme = theme
      })()
    </script>
  </head>
  <body>
    <slot />
    <script src="../scripts/main.js"></script>
  </body>
</html>
