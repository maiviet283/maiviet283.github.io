---
import '../theme.css'
import '../App.css'
import Header from '../components/Header.astro'
import SiteFooter from '../components/SiteFooter.astro'
import text from '../localet/vi.json'

interface Crumb {
  label: string
  href?: string
}

interface Props {
  title: string
  description: string
  keywords?: string
  path: string
  ogType?: string
  crumbLabel: string
  crumbItems?: Crumb[]
  image?: string
  imageAlt?: string
  publishedTime?: string
  modifiedTime?: string
  jsonLd?: object[]
}

const {
  title,
  description,
  keywords,
  path,
  ogType = 'website',
  crumbLabel,
  crumbItems,
  image = '/og-image.png',
  imageAlt,
  publishedTime,
  modifiedTime,
  jsonLd = [],
} = Astro.props

const siteUrl = 'https://maiviet.vietdon.vn'
const canonical = `${siteUrl}${path}`
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`

// Page links shared by the header nav and the footer so every page exposes
// the same primary destinations.
const navLinks = [
  { href: '/', label: 'Trang chủ' },
  { href: '/vietdon/', label: 'VietDon' },
  { href: '/projects/', label: 'Dự án' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'Giới thiệu' },
]

// Breadcrumb: prefer explicit crumbItems, otherwise fall back to the
// simple "Trang chủ / <crumbLabel>" two-level structure.
const crumbs: Crumb[] = crumbItems ?? [
  { label: 'Trang chủ', href: '/' },
  { label: crumbLabel },
]

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((crumb, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.label,
    item: crumb.href ? `${siteUrl}${crumb.href}` : canonical,
  })),
}
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f5402c" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    {keywords ? <meta name="keywords" content={keywords} /> : null}
    <meta name="author" content="Mai Quốc Việt" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="vi" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Open Graph / Facebook / Zalo -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt ?? title} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Mai Quốc Việt – maiviet.vietdon.vn" />
    {publishedTime ? <meta property="article:published_time" content={publishedTime} /> : null}
    {modifiedTime ? <meta property="article:modified_time" content={modifiedTime} /> : null}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt ?? title} />
    <meta name="twitter:creator" content="@maiviet283" />

    <!-- Geo -->
    <meta name="geo.region" content="VN-DN" />
    <meta name="geo.placename" content="Đà Nẵng, Việt Nam" />

    <link rel="stylesheet" href="/pages.css" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    {jsonLd.map((schema) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Apply saved theme before first paint to avoid flashing. -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js')
        var theme = 'dark'
        try {
          theme = localStorage.getItem('theme') || 'dark'
        } catch (error) {}
        document.documentElement.dataset.theme = theme
      })()
    </script>
  </head>
  <body>
    <main class="site-shell">
      <Header text={text} logo="/logo.png" langHref="/en/" nav={navLinks} brandHref="/" />

      <div class="page-wrap">
        <nav class="crumbs" aria-label="Breadcrumb">
          {crumbs.map((crumb, index) => (
            <>
              {index > 0 ? <span> / </span> : null}
              {crumb.href && index < crumbs.length - 1 ? (
                <a href={crumb.href}>{crumb.label}</a>
              ) : (
                <span>{crumb.label}</span>
              )}
            </>
          ))}
        </nav>

        <slot />
      </div>

      <SiteFooter text={text} />
    </main>

    <script src="../scripts/main.js"></script>
  </body>
</html>
